          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/discovery/search": {
      "get": {
        "tags": [
          "discovery"
        ],
        "summary": "Search",
        "description": "Federated search across DuckDuckGo, YouTube, and OpenAlex.\n\nRate limited to 20 requests per minute per user.\nSource labels: ddgs=DuckDuckGo, youtube=YouTube, openalex=OpenAlex",
        "operationId": "search_api_discovery_search_get",
        "parameters": [
          {
            "name": "preset_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Preset Id"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500,
              "title": "Query"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DdgsMetadata": {
        "properties": {
          "source": {
            "type": "string",
            "const": "ddgs",
            "title": "Source",
            "default": "ddgs"
          },
          "domain": {
            "type": "string",
            "title": "Domain"
          },
          "published_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Published Date"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Language"
          }
        },
        "type": "object",
        "required": [
          "domain"
        ],
        "title": "DdgsMetadata",
        "description": "Metadata from DuckDuckGo search results."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "degraded",
              "unhealthy"
            ],
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version",
            "default": "0.1.0"
          },
          "services": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ServiceStatus"
            },
            "type": "object",
            "title": "Services"
          }
        },
        "type": "object",
        "required": [
          "status",
          "services"
        ],
        "title": "HealthResponse",
        "description": "Health check response with detailed service statuses."
      },
      "InternalExchangeRequest": {
        "properties": {
          "email": {
            "type": "string",
            "title": "Email"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "email"
        ],
        "title": "InternalExchangeRequest",
        "description": "Internal token exchange — pre-verified by Next.js server."
      },
      "OAuthLoginRequest": {
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "google",
              "github",
              "facebook"
            ],
            "title": "Provider"
          },
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "email": {
            "type": "string",
            "title": "Email"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "provider",
          "access_token",
          "email"
        ],
        "title": "OAuthLoginRequest",
        "description": "OAuth login request."
      },
      "OpenAlexMetadata": {
        "properties": {
          "source": {
            "type": "string",
            "const": "openalex",
            "title": "Source",
            "default": "openalex"
          },
          "authors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Authors"
          },
          "journal": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Journal"
          },
          "citation_count": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Citation Count"
          },
          "doi": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Doi"
          },
          "published_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Published Date"
          }
        },
        "type": "object",
        "title": "OpenAlexMetadata",
        "description": "Metadata from OpenAlex works results."
      },
      "PaginatedResponse_PresetResponse_": {
        "properties": {
          "data": {
            "items": {
              "$ref": "#/components/schemas/PresetResponse"
            },
            "type": "array",
            "title": "Data"
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "title": "PaginatedResponse[PresetResponse]"
      },
      "PaginationMeta": {
        "properties": {
          "page": {
            "type": "integer",
            "title": "Page",
            "description": "Current page number"
          },
          "limit": {
            "type": "integer",
            "title": "Limit",
            "description": "Items per page"
          },
          "total": {
            "type": "integer",
            "title": "Total",
            "description": "Total number of items"
          },
          "total_pages": {
            "type": "integer",
            "title": "Total Pages",
            "description": "Total number of pages"
          },
          "has_next": {
            "type": "boolean",
            "title": "Has Next",
            "description": "Whether there is a next page"
          },
          "has_prev": {
            "type": "boolean",
            "title": "Has Prev",
            "description": "Whether there is a previous page"
          }
        },
        "type": "object",
        "required": [
          "page",
          "limit",
          "total",
          "total_pages",
          "has_next",
          "has_prev"
        ],
        "title": "PaginationMeta",
        "description": "Pagination metadata."
      },
      "PresetCreate": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name"
          },
          "is_default": {
            "type": "boolean",
            "title": "Is Default",
            "default": false
          },
          "curriculum_framework": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ],
            "title": "Curriculum Framework"
          },
          "subject": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Subject"
          },
          "year_level": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Year Level"
          },
          "topic": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 500
              },
              {
                "type": "null"
              }
            ],
            "title": "Topic"
          },
          "country": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Country"
          },
          "state_region": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 100
              },
              {
                "type": "null"
              }
            ],
            "title": "State Region"
          },
          "city": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 100
              },
              {
                "type": "null"
              }
            ],
            "title": "City"
          },
          "teaching_language": {
            "type": "string",
            "maxLength": 10,
            "minLength": 2,
            "title": "Teaching Language",
            "default": "en"
          },
          "class_size": {
            "anyOf": [
              {
                "type": "integer",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Class Size"
          },
          "eal_d_students": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Eal D Students"
          },
          "reading_support_students": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Reading Support Students"
          },
          "extension_students": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Extension Students"
          },
          "student_interests": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Student Interests"
          },
          "language_backgrounds": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Language Backgrounds"
          },
          "average_reading_level": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 50
              },
              {
                "type": "null"
              }
            ],
            "title": "Average Reading Level"
          },
          "source_weights": {
            "$ref": "#/components/schemas/SourceWeights"
          },
          "additional_notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Additional Notes"
          }
        },
        "type": "object",
        "required": [
          "name",
          "subject",
          "year_level",
          "country"
        ],
        "title": "PresetCreate",
        "description": "Schema for creating a classroom preset."
      },
      "PresetDefaultResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "is_default": {
            "type": "boolean",
            "title": "Is Default"
          }
        },
        "type": "object",
        "required": [
          "id",
          "is_default"
        ],
        "title": "PresetDefaultResponse",
