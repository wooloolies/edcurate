# Project
PROJECT_NAME=edcurate-api
PROJECT_ENV=local

# Database
# Local Docker PostgreSQL:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/edcurate
# Optional: Alembic will derive DATABASE_URL_SYNC from DATABASE_URL when omitted.
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/edcurate
# Production Supabase (replace with actual credentials):
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# DATABASE_URL_SYNC=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Auth (better-auth web server)
BETTER_AUTH_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWE (stateless authentication)
JWE_SECRET_KEY=your-super-secret-jwe-encryption-key-change-in-production

# Redis (optional)
# Local Docker: redis://localhost:6379
# Upstash (production, TLS): rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Weaviate (vector DB)
# Local Docker: http://localhost:8080
# Production: https://<cluster>.weaviate.cloud
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# OpenTelemetry (optional - for production tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=edcurate-api

# Email (optional — required only when verification emails are enabled)
RESEND_API_KEY=
EMAIL_FROM=noreply@pic2cook.org

# AI (optional)
AI_PROVIDER=gemini
GOOGLE_CLOUD_PROJECT=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Storage (optional)
STORAGE_BACKEND=minio
GCS_BUCKET_NAME=
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# OpenAlex
OPENALEX_API_KEY=
