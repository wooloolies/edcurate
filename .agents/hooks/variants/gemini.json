{
  "$schema": "./hook-variant.schema.json",
  "vendor": "gemini",
  "hookDir": ".gemini/hooks",
  "settingsFile": ".gemini/settings.json",
  "projectDirEnv": "GEMINI_PROJECT_DIR",
  "runtime": "bun",
  "events": {
    "BeforeAgent": [
      {
        "hook": "keyword-detector.ts",
        "matcher": "*",
        "timeout": 5000
      },
      {
        "hook": "skill-injector.ts",
        "matcher": "*",
        "timeout": 3000
      }
    ],
    "BeforeTool": {
      "hook": "test-filter.ts",
      "matcher": "run_shell_command",
      "timeout": 5000
    },
    "AfterAgent": {
      "hook": "persistent-mode.ts",
      "matcher": "*",
      "timeout": 5000
    }
  }
}
