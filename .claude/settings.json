{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "keyword-detector",
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/keyword-detector.ts\"",
            "timeout": 5
          },
          {
            "name": "skill-injector",
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-injector.ts\"",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "persistent-mode",
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/persistent-mode.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "name": "test-filter",
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/test-filter.ts\"",
            "timeout": 5
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/hud.ts\""
  },
  "permissions": {
    "allow": [
      "Bash(bun run:*)",
      "Bash(bunx tsx:*)",
      "Bash(git add:*)",
      "mcp__serena__*"
    ]
  },
  "env": {
    "cleanupPeriodDays": 180,
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": 100000,
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": 80,
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "attribution": {
    "commit": "Generated with oh-my-agent\n\nCo-Authored-By: First Fluke <our.first.fluke@gmail.com>",
    "pr": "Generated with [oh-my-agent](https://github.com/first-fluke/oh-my-agent)"
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
