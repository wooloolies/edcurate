{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/keyword-detector.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/persistent-mode.ts",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
